# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mapbox
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token

# Payment gateway (Paystack recommended for Nigeria)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# SMS provider (Termii or Twilio)
VITE_SMS_PROVIDER=termii
VITE_TERMII_API_KEY=your_termii_api_key
# Or Twilio:
# VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
# VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Push notifications (Firebase Cloud Messaging)
VITE_FCM_VAPID_KEY=your_fcm_vapid_key

# Transactional email (Resend)
VITE_RESEND_API_KEY=re_your_resend_key

# App
VITE_APP_URL=http://localhost:5173
